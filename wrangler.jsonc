{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "romaran",
  "compatibility_date": "2026-05-02",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "romaran-db",
      "database_id": "YOUR_PRODUCTION_D1_DATABASE_ID_HERE"
    }
  ]
}
